# All features work without any API keys. Transcription uses local Whisper + yt-dlp subtitles.
# Summarization is done by Claude Code in-session (free) or via local extractive summarizer.

# Optional: enables cloud-based summarization via Claude API (NOT required, costs money)
# ANTHROPIC_API_KEY=
# SUMMARIZER_MODEL=claude-sonnet-4-20250514

# Optional: force a specific Whisper model (default: auto-selects based on video duration)
# Videos <= 10min use "base", longer videos use "tiny"
# WHISPER_MODEL=
