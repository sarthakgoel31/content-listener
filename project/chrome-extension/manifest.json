{
  "manifest_version": 3,
  "name": "VidText",
  "version": "1.1.0",
  "description": "Turn videos, reels & podcasts into text, summaries, and Kindle reads",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://youtu.be/*",
    "https://www.instagram.com/*",
    "https://open.spotify.com/*",
    "http://localhost:8420/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.instagram.com/*",
        "https://open.spotify.com/*"
      ],
      "js": ["content.js"],
      "css": ["content-overlay.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}